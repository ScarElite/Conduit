{
  "name": "conduit",
  "productName": "Conduit",
  "version": "1.0.0",
  "description": "A custom, fully themeable terminal emulator for Windows. Also ships an embeddable React <Terminal/> component (lib/) for V's Command Hub.",
  "main": ".vite/build/main.js",
  "module": "./lib/conduit-terminal.js",
  "exports": {
    ".": {
      "import": "./lib/conduit-terminal.js"
    },
    "./style.css": "./lib/conduit-terminal.css",
    "./package.json": "./package.json"
  },
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "typecheck": "tsc --noEmit",
    "rebuild": "electron-rebuild -f -w node-pty",
    "build:lib": "vite build --config vite.lib.config.ts",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "keywords": [],
  "author": {
    "name": "Mitchell Armstrong",
    "email": "mra0211@gmail.com"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.4",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^22.19.21",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "42.4.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "patch-package": "^8.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^8.2.0",
    "node-pty": "1.1.0"
  }
}
